    ToggleBtn.MouseButton1Click:Connect(function()
        Config.IsDominant = not Config.IsDominant
        ToggleBtn.Text = Config.IsDominant and "ROLE: DOMINANT" or "ROLE: NON-DOMINANT"
        ToggleBtn.TextColor3 = Config.IsDominant and Color3.fromRGB(0, 255, 127) or Color3.fromRGB(255, 69, 0)
