--[[
    KAT CO-OP SYNC SCRIPT - V2 (Refined)
    Features:
    - Dominant/Non-Dominant Role Selection (via GUI)
    - Local Persistence (saves choice)
    - Underground Teleportation (0, -500, 0)
    - Anti-Fall Platform
    - Precise Facing & Camera Aim for Action
    - Coordinated Server Hopping (JobId Sharing)
]]

local Players = game:GetService("Players")

-- Clean up old instances (Prevents execution failure on executors that don't wipe CoreGui between hops)
local existingGui = game.CoreGui:FindFirstChild("KAT_Sync_GUI")
if existingGui then
    existingGui:Destroy()
end

-- Wait for LocalPlayer to load if running in autoexec early injection
while not Players.LocalPlayer do
    task.wait(0.1)
end
local LocalPlayer = Players.LocalPlayer

local HttpService = game:GetService("HttpService")
local TeleportService = game:GetService("TeleportService")
local RunService = game:GetService("RunService")
local VirtualInputManager = game:GetService("VirtualInputManager")
local GuiService = game:GetService("GuiService")

-- Automatically close Roblox error prompts (like "Teleport Failed") so it doesn't block gameplay
GuiService.ErrorMessageChanged:Connect(function()
    pcall(function()
        GuiService:ClearError()
    end)
end)

-- CONFIGURATION
local SCRIPT_URL = "https://raw.githubusercontent.com/TheK3R1M/Roblox-Script-denemeleri/refs/heads/main/scripts/KAT?token=GHSAT0AAAAAADUJINNUQHOWVCW7FL6VNZXU2NXHTVA" -- (OPTIONAL) PUT YOUR GITHUB/PASTEBIN RAW SCRIPT LINK HERE FOR 100% RELIABLE AUTO-EXECUTE BETWEEN SERVERS
local TARGET_COORD = Vector3.new(0, -500, 0)
local NON_DOMINANT_OFFSET = Vector3.new(0, 0, -3) -- 3 studs directly in front
local CONFIG_FILE = "KAT_Sync_Config_" .. tostring(LocalPlayer.Name) .. ".json"
local CLIENTS_FILE = "KAT_Sync_Clients.json"
local SYNC_FILE = "KAT_Target_Server.json"
local PLACE_ID = game.PlaceId

-- STATE
local Config = {
    IsDominant = false,
    InitialGems = -1,
    SessionGems = 0
}

-- LOAD CONFIG
local function LoadConfig()
    if isfile(CONFIG_FILE) then
        local success, decrypted = pcall(function()
            return HttpService:JSONDecode(readfile(CONFIG_FILE))
        end)
        if success and typeof(decrypted) == "table" then 
            Config.IsDominant = decrypted.IsDominant or false
            Config.InitialGems = decrypted.InitialGems or -1
            Config.SessionGems = decrypted.SessionGems or 0
        end
    end
end

-- SAVE CONFIG
local function SaveConfig()
    writefile(CONFIG_FILE, HttpService:JSONEncode(Config))
end

-- GEM TRACKER UTIL
local function GetCurrentGems()
    local path = LocalPlayer:FindFirstChild("PlayerGui")
    if not path then return nil end
    local val = path:FindFirstChild("GameUI")
            and path.GameUI:FindFirstChild("Menu")
            and path.GameUI.Menu:FindFirstChild("InventoryUI")
            and path.GameUI.Menu.InventoryUI:FindFirstChild("ShopScreen")
            and path.GameUI.Menu.InventoryUI.ShopScreen:FindFirstChild("Static")
            and path.GameUI.Menu.InventoryUI.ShopScreen.Static:FindFirstChild("strip")
            and path.GameUI.Menu.InventoryUI.ShopScreen.Static.strip:FindFirstChild("gemHolder")
            and path.GameUI.Menu.InventoryUI.ShopScreen.Static.strip.gemHolder:FindFirstChild("GemValue")
            
    if val then
        if val:IsA("IntValue") or val:IsA("NumberValue") then
            return val.Value
        elseif val:IsA("TextLabel") or val:IsA("TextBox") then
            local rawStr = string.gsub(val.Text, "[^%d]", "")
            return tonumber(rawStr)
        end
    end
    return nil
end

-- PRESENCE REGISTRY
local function UpdateClientPresence()
    task.spawn(function()
        local clients = {}
        if isfile(CLIENTS_FILE) then
            local success, content = pcall(function() return readfile(CLIENTS_FILE) end)
            if success and content and content ~= "" then
                pcall(function() clients = HttpService:JSONDecode(content) end)
            end
        end
        clients[LocalPlayer.Name] = {
            Role = Config.IsDominant and "Dominant" or "NonDominant",
            LastSeen = tick()
        }
        pcall(function() writefile(CLIENTS_FILE, HttpService:JSONEncode(clients)) end)
    end)
end

local function GetActiveNonDominants()
    local clients = {}
    if isfile(CLIENTS_FILE) then
        local success, content = pcall(function() return readfile(CLIENTS_FILE) end)
        if success and content and content ~= "" then
            pcall(function() clients = HttpService:JSONDecode(content) end)
        end
    end
    local count = 0
    for name, data in pairs(clients) do
        if data.Role == "NonDominant" and (tick() - data.LastSeen < 15) then
            count = count + 1
        end
    end
    return count
end

