    return StatusLabel, StartBtn, GemLabel
end


-- UTILS
local function CreatePlatform()
    local platform = Instance.new("Part")
    platform.Name = "SyncPlatform"
    platform.Size = Vector3.new(20, 1, 20)
    platform.Position = TARGET_COORD - Vector3.new(0, 5, 0)
    platform.Anchored = true
    platform.Parent = workspace
    return platform
end

local function GetNextServer()
    -- Attempt 1: Using a known proxy (roproxy)
    -- Changed sortOrder to Asc (Ascending) so we get the emptiest servers first.
    local url = "https://games.roproxy.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100"
    local success, raw = pcall(function() return game:HttpGet(url) end)
    
    -- Attempt 2: Direct Roblox API (if executor allows it)
    if not success or not raw or raw:find("err") then
        url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100"
        success, raw = pcall(function() return game:HttpGet(url) end)
    end

    if not success then 
        warn("KAT SYNC: Failed to fetch server list HTTP error.")
        return nil 
    end

    local decodeSuccess, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not decodeSuccess or not data or not data.data then 
        warn("KAT SYNC: Failed to decode JSON or invalid format.")
        return nil 
    end
    
    local validServers = {}
    for _, server in ipairs(data.data) do
        -- Skip 0-player servers (Ghost servers that often crash/error)
        -- Ensure server has between 1 and 8 players to leave plenty of room for our group
        if server.playing and server.maxPlayers and server.playing > 0 and server.playing < 8 and (server.maxPlayers - server.playing >= 3) and server.id ~= game.JobId then
            table.insert(validServers, server.id)
        end
    end
    
    if #validServers > 0 then
        math.randomseed(tick())
        local chosen = validServers[math.random(1, #validServers)]
        return chosen
    end
    
    warn("KAT SYNC: No suitable server found in the list.")
    return nil
end

-- QUEUE ON TELEPORT (Ensures script runs in new server)
local TeleportHooked = false
local function AutoInjectNextServer()
    if TeleportHooked then return end
    TeleportHooked = true
    
    local queueFunction = syn and syn.queue_on_teleport or queue_on_teleport or (fluxus and fluxus.queue_on_teleport)
    if queueFunction then
        
        local payload = ""
        if SCRIPT_URL and SCRIPT_URL ~= "" then
            payload = "loadstring(game:HttpGet('" .. SCRIPT_URL .. "'))()"
        else
            payload = [[
                task.wait(3)
                
                local loaded = false
                local possibleNames = {"KAT_Sync_Script.lua", "KAT.lua", "sync.lua", "kat_sync.lua", "autoexec.lua"}
                
                for _, name in ipairs(possibleNames) do
                    if isfile(name) then
                        local src = readfile(name)
                        if src:find("KAT CO%-OP SYNC SCRIPT") then
                            local s, err = pcall(function() loadstring(src)() end)
                            if s then loaded = true break end
                        end
                    end
                end
                
                if not loaded then
                    warn("KAT SYNC ERROR: I couldn't find my own file to auto-execute!")
                    warn("SOLUTION: You must put a link in SCRIPT_URL.")
                end
            ]]
        end
        
        -- Strategy 1: Queue immediately (Works best for generic/budget executors)
        pcall(function() queueFunction(payload) end)
        
        -- Strategy 2: Queue right on teleport state change (Works best for older/premium executors)
        LocalPlayer.OnTeleport:Connect(function()
            pcall(function() queueFunction(payload) end)
        end)
    end
end

local AppThreadsStarted = false
local function StartAppThreads(StatusLabel, GemLabel)
    if AppThreadsStarted then return end
    AppThreadsStarted = true
    
    -- Start heartbeat
    task.spawn(function()
        while true do
            UpdateClientPresence()
            task.wait(3)
        end
    end)
    
    -- Gem Tracker Component
    task.spawn(function()
        while true do
            local current = GetCurrentGems()
            if current ~= nil then
                if Config.InitialGems == -1 then
                    Config.InitialGems = current
                    SaveConfig()
                end
                
                local earned = current - Config.InitialGems
                if earned < 0 then
                    -- They likely spent gems, reset baseline
                    Config.InitialGems = current
                    earned = 0
                    SaveConfig()
                end
                
                Config.SessionGems = earned
                
                local newText = "💎 Farmed: " .. tostring(earned) .. " | Total: " .. tostring(current)
                if GemLabel.Text ~= newText then
                    GemLabel.Text = newText
                    SaveConfig()
                end
            end
            task.wait(2)
        end
    end)
end

-- LOGIC
local function Main(StatusLabel, GemLabel)
    StartAppThreads(StatusLabel, GemLabel)

    StatusLabel.Text = "Waiting for Spawn..."
    
    -- Wait for spawn
    while true do
        local character = LocalPlayer.Character
        if character and character:FindFirstChild("HumanoidRootPart") then
            local spawnedVal = workspace:FindFirstChild(LocalPlayer.Name) and workspace[LocalPlayer.Name]:FindFirstChild("HasSpawned")
            if spawnedVal and spawnedVal.Value == true then
                break
            end
        end
        task.wait(0.5)
    end

    StatusLabel.Text = "Teleporting..."
    CreatePlatform()
    
    local character = LocalPlayer.Character
    local hrp = character.HumanoidRootPart
    local humanoid = character:FindFirstChildOfClass("Humanoid")

    -- Teleport and make players face each other
    if Config.IsDominant then
        -- Dominant faces the spot where Non-Dominant will be
        hrp.CFrame = CFrame.new(TARGET_COORD, TARGET_COORD + NON_DOMINANT_OFFSET)
    else
        -- Non-dominant stands 3 studs in front and faces the Dominant
        hrp.CFrame = CFrame.new(TARGET_COORD + NON_DOMINANT_OFFSET, TARGET_COORD)
    end

    task.wait(1)

    if Config.IsDominant then
        StatusLabel.Text = "Waiting for Targets..."
        -- Wait for all active Non-Dominant accounts to arrive
        local targets = {}
        while true do
            local expectedCount = GetActiveNonDominants()
            if expectedCount == 0 then expectedCount = 1 end
            
            targets = {}
            for _, p in ipairs(Players:GetPlayers()) do
                if p ~= LocalPlayer and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
                    local dist = (p.Character.HumanoidRootPart.Position - hrp.Position).Magnitude
                    if dist < 8 then
                        table.insert(targets, p)
                    end
                end
            end
            if #targets >= expectedCount then break end
            
            StatusLabel.Text = "Waiting for Targets ("..#targets.."/"..expectedCount..")..."
            task.wait(0.5)
        end

        local backpack = LocalPlayer:FindFirstChild("Backpack")
        if humanoid and backpack then
            for _, item in ipairs(backpack:GetChildren()) do
                if item.Name:lower():find("knife") or item:IsA("Tool") then
                    humanoid:EquipTool(item)
                    break
                end
            end
        end
        task.wait(1.5) -- Wait longer to ensure equip anim plays and weapon is ready
        local viewportSize = workspace.CurrentCamera.ViewportSize

        for i, targetPlayer in ipairs(targets) do
            if not targetPlayer or not targetPlayer.Character or not targetPlayer.Character:FindFirstChild("Humanoid") then
                continue
            end
            if targetPlayer.Character.Humanoid.Health <= 0 then
                continue 
            end
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health <= 0 then
                StatusLabel.Text = "Died during combat! Restarting..."
                task.wait(2)
                return Main(StatusLabel, GemLabel)
            end

            StatusLabel.Text = "Waiting for ForceField ("..i.."/"..#targets..")"
            -- Wait until Spawn Invincibility (ForceField) is gone from both players
            while true do
                if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health <= 0 then break end
                local myFF = character:FindFirstChildOfClass("ForceField")
                local targetFF = targetPlayer.Character:FindFirstChildOfClass("ForceField")
                if not myFF and not targetFF then
                    break
                end
                if targetPlayer.Character.Humanoid.Health <= 0 then
                    break
                end
                task.wait(0.5)
            end
            
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health <= 0 then
                StatusLabel.Text = "Died! Restarting..."
                task.wait(2)
                return Main(StatusLabel, GemLabel)
            end

            -- Loop click until target is dead
            StatusLabel.Text = "Attacking Target ("..i.."/"..#targets..")"
            local maxAttempts = 30 -- Increase max attempts to be safe
            local attempts = 0
            
            while targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("Humanoid") and targetPlayer.Character.Humanoid.Health > 0 and attempts < maxAttempts do
                
                -- Support aiming locally if preferred
                hrp.CFrame = CFrame.new(hrp.Position, Vector3.new(targetPlayer.Character.HumanoidRootPart.Position.X, hrp.Position.Y, targetPlayer.Character.HumanoidRootPart.Position.Z))

                -- Just fire the virtual click directly without forcing the camera
                VirtualInputManager:SendMouseButtonEvent(viewportSize.X / 2, viewportSize.Y / 2, 0, true, game, 0)
                task.wait(0.1)
                VirtualInputManager:SendMouseButtonEvent(viewportSize.X / 2, viewportSize.Y / 2, 0, false, game, 0)
                task.wait(0.5)
                attempts = attempts + 1
            end
            
            if attempts >= maxAttempts then
                StatusLabel.Text = "Kill Timeout ("..i..")!"
            else
                StatusLabel.Text = "Kill Registered ("..i..")!"
                
                -- Verify the kill on the KillFeed UI
                StatusLabel.Text = "Verifying KillFeed ("..i..")..."
                local feedVerified = false
                local killDelayAttempts = 0
                while killDelayAttempts < 50 do -- Wait up to 5 seconds for the feed to show
                    pcall(function()
                        local killFeed = LocalPlayer.PlayerGui:FindFirstChild("GameUI")
                            and LocalPlayer.PlayerGui.GameUI:FindFirstChild("HUD")
                            and LocalPlayer.PlayerGui.GameUI.HUD:FindFirstChild("KillFeed")
                            
                        if killFeed then
                            for _, child in ipairs(killFeed:GetChildren()) do
                                if child.Name == "KillFeedTemplate" and child:FindFirstChild("Contents") then
                                    local killerLbl = child.Contents:FindFirstChild("Killer")
                                    local targetLbl = child.Contents:FindFirstChild("Target")
                                    if killerLbl and targetLbl and killerLbl.Text == LocalPlayer.Name and targetLbl.Text == targetPlayer.Name then
                                        feedVerified = true
                                    end
                                end
                            end
                        end
                    end)
                    if feedVerified then break end
                    killDelayAttempts = killDelayAttempts + 1
                    task.wait(0.1)
                end
                
                if feedVerified then
                    StatusLabel.Text = "Target "..i.." Verified!"
                else
                    StatusLabel.Text = "Target "..i.." Unverified! (Timeout)"
                end
            end
            task.wait(0.5) -- Short delay after confirmed kill
        end
        
        StatusLabel.Text = "All Kills Processed!"
        task.wait(1) 
        
        -- PRE-HOP DEATH CHECK
        if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health <= 0 then
            StatusLabel.Text = "Died before hop! Retrying..."
            task.wait(2)
            return Main(StatusLabel, GemLabel)
        end
        
        -- Coordinated Server Hop
        local function AttemptHop(forcedJobId)
            StatusLabel.Text = "Choosing Server..."
            local nextJobId = forcedJobId or GetNextServer()
            if nextJobId then
                -- Only write the file if we are picking a new server, not retrying an existing one
                if not forcedJobId then
                    writefile(SYNC_FILE, HttpService:JSONEncode({JobId = nextJobId, Time = tick()}))
                end
                StatusLabel.Text = "Hopping..."
                AutoInjectNextServer()
                
                -- Catch Roblox Teleport failures before kicking
                local connection
                connection = TeleportService.TeleportInitFailed:Connect(function()
                    connection:Disconnect()
                    StatusLabel.Text = "Teleport Failed! Retrying in 5s..."
                    task.wait(5)
                    AttemptHop(nextJobId) -- CRITICAL: Retry the SAME server, do not pick a new one!
                end)

                local isTeleporting = false
                local tpConnection = LocalPlayer.OnTeleport:Connect(function()
                    isTeleporting = true
                end)

                local tsSuccess, err = pcall(function()
                    TeleportService:TeleportToPlaceInstance(PLACE_ID, nextJobId, LocalPlayer)
                end)
                
                if not tsSuccess then
                    if connection.Connected then connection:Disconnect() end
                    if tpConnection.Connected then tpConnection:Disconnect() end
                    StatusLabel.Text = "Hop Execution Error! Retrying..."
                    task.wait(2)
                    AttemptHop(nextJobId)
                end
                
                -- Timeout catch just in case it stalls silently
                task.delay(15, function()
                    if connection.Connected then connection:Disconnect() end
                    if tpConnection.Connected then tpConnection:Disconnect() end
                    
                    if not isTeleporting then
                        StatusLabel.Text = "Hop Timeout! Retrying..."
                        AttemptHop(nextJobId)
                    end
                end)
            else
                StatusLabel.Text = "Hop Failed! Retrying..."
                task.wait(2)
                AttemptHop()
            end
        end
        AttemptHop()

    else
        StatusLabel.Text = "Waiting for Sync..."
        -- Poll for server change
        while true do
            -- SAFEGUARD: If Non-Dominant dies while waiting, restart to teleport back underground
            if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("Humanoid") or LocalPlayer.Character.Humanoid.Health <= 0 then
                StatusLabel.Text = "Died while waiting! Restarting..."
                task.wait(2)
                return Main(StatusLabel, GemLabel)
            end
            
            if isfile(SYNC_FILE) then
                local success, data = pcall(function()
                    return HttpService:JSONDecode(readfile(SYNC_FILE))
                end)
                -- If the file was written reasonably recently (10 mins) and is a different server
                if success and data.JobId and (tick() - data.Time < 600) and data.JobId ~= game.JobId then
                    StatusLabel.Text = "Following to Server..."
                    AutoInjectNextServer()
                    
                    local connection
                    connection = TeleportService.TeleportInitFailed:Connect(function()
                        connection:Disconnect()
                        StatusLabel.Text = "Follow Failed (Init)! Retrying..."
                    end)

                    local isTeleporting = false
                    local tpConnection = LocalPlayer.OnTeleport:Connect(function()
                        isTeleporting = true
                    end)

                    local tsSuccess, err = pcall(function()
                        TeleportService:TeleportToPlaceInstance(PLACE_ID, data.JobId, LocalPlayer)
                    end)
                    if not tsSuccess then
                        if connection.Connected then connection:Disconnect() end
                        if tpConnection.Connected then tpConnection:Disconnect() end
                        StatusLabel.Text = "Following Failed! Retrying..."
                    end
                    task.delay(10, function()
                        if connection.Connected then connection:Disconnect() end
                        if tpConnection.Connected then tpConnection:Disconnect() end
                    end)
                    
                    task.wait(5) -- Wait before retrying if tp failed
                end
            end
            task.wait(1)
        end
    end
end

-- Initialization
LoadConfig()
local StatusLabel, StartBtn, GemLabel = CreateGUI()

StartBtn.MouseButton1Click:Connect(function()
    StartBtn.Visible = false
    -- Manual start rests the gem farming session
    Config.InitialGems = -1
    Config.SessionGems = 0
    SaveConfig()
    
    Main(StatusLabel, GemLabel)
end)

-- Auto Start check (If we have a valid recent sync file, we assume we just hopped, start automatically)
if isfile(SYNC_FILE) then
    local success, data = pcall(function() return HttpService:JSONDecode(readfile(SYNC_FILE)) end)
    -- If file was updated within 3 mins, assume we hopped and auto-start logic
    if success and data.Time and (tick() - data.Time < 180) then
        StartBtn.Visible = false
        -- Auto-start DOES NOT reset InitialGems, keeping the session running across hops
        Main(StatusLabel, GemLabel)
    end
end
