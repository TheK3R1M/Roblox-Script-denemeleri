local function IsPlayerAlive(player)
    if not player or not player.Character then return false end
    local h = player.Character:FindFirstChildOfClass("Humanoid")
    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
    if not h or not hrp then return false end
    if h.Health <= 0 then return false end
    if player.Character:FindFirstChildOfClass("ForceField") then return false end
    
    -- Check if player has actually spawned (NOT HasSpawnedLobby)
    local wsPlayer = workspace:FindFirstChild(player.Name)
    if wsPlayer then
        local hasSpawned = wsPlayer:FindFirstChild("HasSpawned")
        -- In some versions it's a BoolValue, in others it might be a child name only
        if hasSpawned and hasSpawned:IsA("ValueBase") and hasSpawned.Value == false then 
            return false 
        end
    end
    return true
end

-- TEAM DEATHMATCH: Check outline color to determine team
local function GetTeamOutlineColor(playerName)
    local wsPlayer = workspace:FindFirstChild(playerName)
    if wsPlayer then
        local teamHL = wsPlayer:FindFirstChild("TeamHL")
        if teamHL and teamHL:IsA("Highlight") then
            return teamHL.OutlineColor
        end
    end
    return nil
end

local function IsEnemy(player)
    -- Check if TeamDeathmatch mode
    local modeVal = workspace:FindFirstChild("Gamemode")
    if not modeVal or tostring(modeVal.Value) ~= "TeamDeathmatch" then
        return true -- Not TDM, everyone is an enemy
    end
    
    local myColor = GetTeamOutlineColor(LocalPlayer.Name)
    local theirColor = GetTeamOutlineColor(player.Name)
    
    if not myColor or not theirColor then 
        Log("TDM: Could not find team color for " .. player.Name)
        return true 
    end
    
    local result = myColor ~= theirColor
    if not result then
        Log("TDM: Skipping Teammate " .. player.Name)
    end
    return result
end

local function IsLocalPlayerAlive()
    local char = LocalPlayer.Character
    if not char then return false end
    local h = char:FindFirstChildOfClass("Humanoid")
    return h and h.Health > 0
end

-- Read the game's assigned target from the HUD
local function GetAssignedTarget()
    local success, targetName = pcall(function()
        local tName = LocalPlayer.PlayerGui
            :FindFirstChild("GameUI")
            and LocalPlayer.PlayerGui.GameUI:FindFirstChild("HUD")
            and LocalPlayer.PlayerGui.GameUI.HUD:FindFirstChild("TargetUI")
            and LocalPlayer.PlayerGui.GameUI.HUD.TargetUI:FindFirstChild("TargetHolder")
            and LocalPlayer.PlayerGui.GameUI.HUD.TargetUI.TargetHolder:FindFirstChild("TargetName")
        if tName then
            local txt = ""
            if tName:IsA("TextLabel") or tName:IsA("TextBox") then
                txt = tName.Text
            elseif tName:IsA("StringValue") then
                txt = tName.Value
            end
            return txt
        end
        return nil
    end)
    if success and targetName and targetName ~= "" then
        Log("HUD Target Name Found:", targetName)
        -- Find the Player object from the name
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Name == targetName and player ~= LocalPlayer then
                return player
            end
        end
        Log("HUD Target " .. targetName .. " is not in the player list")
    end
    return nil
end

