local function EmergencyHop(StatusLabel, reason)
    StatusLabel.Text = "⚠️ " .. reason .. " HOPPING!"
    -- CRITICAL: Clean up before teleport to prevent freeze
    StopFlyLock()
    DisableNoclip()
    AutoInjectNextServer()
    SERVER_LIST_CACHE = nil
    local nextJobId = GetNextServer()
    if nextJobId then
        Config.HopCount = Config.HopCount + 1
        SaveConfig()
        pcall(function() TeleportService:TeleportToPlaceInstance(PLACE_ID, nextJobId, LocalPlayer) end)
    end
end

