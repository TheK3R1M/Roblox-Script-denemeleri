-- ═══════════════════════════════════════
local function Main(StatusLabel, KillLabel, HopLabel, TimerLabel)
    -- Anti-AFK
    pcall(function()
        LocalPlayer.Idled:Connect(function()
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.W, false, game)
            task.wait(0.1)
            VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.W, false, game)
        end)
    end)

    -- 🛡️ Anti-Void & Anti-Sit (Background)
    local mySession = scriptState.SessionId
    task.spawn(function()
        while not scriptState.Destroyed and scriptState.SessionId == mySession do
            if not scriptState.Stopped then
                local char = LocalPlayer.Character
                local h = char and char:FindFirstChildOfClass("Humanoid")
                local hrp = char and char:FindFirstChild("HumanoidRootPart")

                if h and hrp then
                    -- 🛑 Anti-Sit
                    if h.Sit then
                        h.Sit = false
                        h:ChangeState(Enum.HumanoidStateType.Jump)
                    end

                    -- 🌌 Anti-Void
                    if hrp.Position.Y < -50 then
                        Log("VOID DETECTED! Teleporting to safety.")
                        hrp.Velocity = Vector3.new(0, 0, 0)
                        hrp.CFrame = CFrame.new(0, 50, 0) -- Teleport to a default "Sky" position
                    end
                end
            end
            task.wait(0.3)
        end
    end)

    -- Vote Kick Scanner (background)
    local mySession = scriptState.SessionId
    task.spawn(function()
        while not scriptState.Destroyed and scriptState.SessionId == mySession do
            if not scriptState.Stopped then
                if IsBeingVoteKicked() then
                    EmergencyHop(StatusLabel, "VOTE KICK!")
                    return
                end
            end
            task.wait(0.5)
        end
    end)

    -- 15-Minute Timer (background)
    local hopStartTime = tick()
    task.spawn(function()
        while not scriptState.Destroyed and scriptState.SessionId == mySession do
            if not scriptState.Stopped then
                local elapsed = tick() - hopStartTime
                local remaining = math.max(0, SERVER_HOP_INTERVAL - elapsed)
                local mins = math.floor(remaining / 60)
                local secs = math.floor(remaining % 60)
                TimerLabel.Text = string.format("⏱️ Next Hop: %02d:%02d", mins, secs)

                if remaining <= 0 then
                    StatusLabel.Text = "⏱️ Timer hop!"
                    task.wait(1)
                    EmergencyHop(StatusLabel, "15 MIN TIMER")
                    return
                end
            end
            task.wait(1)
        end
    end)

    -- Auto-Purchase Claymore (ONE TIME only)
    task.spawn(function()
        task.wait(10)
        if scriptState.Destroyed or scriptState.Stopped then return end
        pcall(function()
            local Event = LocalPlayer.PlayerGui
                :FindFirstChild("GameUI")
                and LocalPlayer.PlayerGui.GameUI:FindFirstChild("ClientMaster")
                and LocalPlayer.PlayerGui.GameUI.ClientMaster:FindFirstChild("Interact")
                and LocalPlayer.PlayerGui.GameUI.ClientMaster.Interact:FindFirstChild("88")
            
            if Event then
                firesignal(Event.OnClientEvent, 
                    true,
                    "Claymore",
                    "KnifeSkins",
                    {SID = 5}
                )
            end
        end)
    end)

    -- Wait for character
    StatusLabel.Text = "Waiting for spawn..."
    while not scriptState.Stopped do
        if IsLocalPlayerAlive() then break end
        task.wait(0.5)
    end
    if scriptState.Stopped then DisableNoclip() return end

    -- ═══ MAIN KILL LOOP ═══
    EnableNoclip()
    local skipList = {} -- Players we couldn't kill → skip for 10s
    
    while not scriptState.Stopped and not scriptState.Destroyed do
        if not IsLocalPlayerAlive() then
            StatusLabel.Text = "Dead! Waiting respawn..."
            while not scriptState.Stopped and not IsLocalPlayerAlive() do
                task.wait(0.5)
            end
            if scriptState.Stopped then break end
            EnableNoclip()
            StatusLabel.Text = "Respawned!"
        end

        -- Vote kick check
        if IsBeingVoteKicked() then
            DisableNoclip()
            EmergencyHop(StatusLabel, "VOTE KICK!")
            return
        end

        -- Server population check: Hop if only 1 other player (or none) left
        if #Players:GetPlayers() <= 2 then
            StatusLabel.Text = "👤 Low players, hopping..."
            task.wait(2)
            EmergencyHop(StatusLabel, "LOW PLAYERS")
            return
        end

        -- PRIORITY 1: Read the game's assigned target from TargetUI
        local bestTarget = GetAssignedTarget()
        
        -- Validate assigned target is alive AND enemy
        if bestTarget and (not IsPlayerAlive(bestTarget) or not IsEnemy(bestTarget)) then
            bestTarget = nil
        end
        
        -- PRIORITY 2: Focus Cheaters/Exploiters
        if not bestTarget then
            for name, isCheat in pairs(CheaterRadar) do
                if isCheat then
                    local p = Players:FindFirstChild(name)
                    if p and IsPlayerAlive(p) and IsEnemy(p) then
                        bestTarget = p
                        Log("RADAR FOCUS: Targeting Cheater", p.Name)
                        break
                    else
                        CheaterRadar[name] = nil -- Player left or died
                    end
                end
            end
        end

        -- PRIORITY 3: Fallback to nearest alive enemy (with rotation cycle)
        if not bestTarget then
            local bestDist = math.huge
            local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
            if myHRP then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and IsPlayerAlive(player) and IsEnemy(player) then
                        -- Check cycle delay
                        local lastAtk = skipList[player.Name] or 0
                        if tick() - lastAtk > 1.5 then
                            local theirHRP = player.Character:FindFirstChild("HumanoidRootPart")
                            if theirHRP then
                                local dist = (theirHRP.Position - myHRP.Position).Magnitude
                                if dist < bestDist then
                                    bestDist = dist
                                    bestTarget = player
                                end
                            end
                        end
                    end
                end
            end
            
            -- If everyone is in cooldown, pick anyone to avoid standing still
            if not bestTarget then
                for _, player in ipairs(Players:GetPlayers()) do
                    if player ~= LocalPlayer and IsPlayerAlive(player) and IsEnemy(player) then
                        bestTarget = player
                        break
                    end
                end
            end
        end

        if bestTarget and IsPlayerAlive(bestTarget) then
            Log("Target selected:", bestTarget.Name)
            StatusLabel.Text = "🎯 " .. bestTarget.Name
            
            -- Equip knife
            EnsureKnifeEquipped()

            -- Wait for target's ForceField to expire before attacking
            local canAttack = true
            if bestTarget.Character and bestTarget.Character:FindFirstChildOfClass("ForceField") then
                Log(bestTarget.Name .. " has ForceField, waiting...")
                StatusLabel.Text = "⏳ " .. bestTarget.Name .. " FF..."
                while not scriptState.Stopped and IsPlayerAlive(bestTarget) do
                    if not bestTarget.Character:FindFirstChildOfClass("ForceField") then break end
                    task.wait(0.1) -- Fast FF check
                end
                if scriptState.Stopped or not IsPlayerAlive(bestTarget) then
                    Log("Target lost or stopped during FF wait")
                    canAttack = false
                end
            end

            if canAttack then
                -- ═══ FLY-LOCK ATTACK ═══
                Log("Starting FlyLock on", bestTarget.Name)
                StartFlyLock(bestTarget)
                
                local atkAttempts = 0
                local MAX_ATK = 3 -- Very fast rotate (1-2 hits then swap)
                
                while not scriptState.Stopped 
                    and IsPlayerAlive(bestTarget) 
                    and IsLocalPlayerAlive() 
                    and atkAttempts < MAX_ATK do
                    
                    if not IsEnemy(bestTarget) then 
                        break 
                    end
                    
                    -- No EnsureKnifeEquipped inside loop for speed
                    AttackTarget()
                    
                    task.wait(ATTACK_COOLDOWN)
                    atkAttempts = atkAttempts + 1
                end
                
                -- Release lock
                StopFlyLock()
                Log("FlyLock released for", bestTarget.Name)

                -- Check kill
                if not IsPlayerAlive(bestTarget) then
                    Log("Kill confirmed:", bestTarget.Name)
                    Config.SessionKills = Config.SessionKills + 1
                    Config.TotalKills = Config.TotalKills + 1
                    SaveConfig()
                    KillLabel.Text = "🗡️ Kills: " .. Config.TotalKills .. " (Session: " .. Config.SessionKills .. ")"
                    StatusLabel.Text = "✅ " .. bestTarget.Name .. " killed!"
                else
                    -- Still alive? Add to 1.5s rotation cooldown so we pick someone else next
                    skipList[bestTarget.Name] = tick()
                end
            end
            -- NO WAIT — immediately find next target
        else
            -- Log scan once in a while
            if math.random(1, 20) == 1 then
                Log("Still scanning for targets... (Current players: " .. #Players:GetPlayers() .. ")")
            end
            StatusLabel.Text = "🔍 Scanning..."
            task.wait(KILL_SCAN_INTERVAL)
        end
    end

    DisableNoclip()
end

