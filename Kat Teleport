        if SCRIPT_URL and SCRIPT_URL ~= "https://raw.githubusercontent.com/TheK3R1M/Roblox-Script-denemeleri/refs/heads/main/Kat%20Teleport" then
            payload = [[
                local s, code = pcall(function() return game:HttpGet("]] .. SCRIPT_URL .. [[") end)
                if s and code and code ~= "" then
                    Log("Auto-Inject: Code fetched from URL")
                    loadstring(code)()
