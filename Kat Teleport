-- SERVER HOP
-- ═══════════════════════════════════════
local SERVER_LIST_CACHE = nil
local LAST_FETCH_TIME = 0

local function GetNextServer()
    if SERVER_LIST_CACHE and (tick() - LAST_FETCH_TIME < 10) then
        return SERVER_LIST_CACHE[math.random(1, #SERVER_LIST_CACHE)]
    end

    local url = "https://games.roproxy.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100"
    local success, raw = pcall(function() return game:HttpGet(url) end)
    
    if not success or not raw or raw:find("err") then
        url = "https://games.roblox.com/v1/games/" .. PLACE_ID .. "/servers/Public?sortOrder=Asc&limit=100"
        success, raw = pcall(function() return game:HttpGet(url) end)
    end
    if not success then return nil end

    local ok, data = pcall(function() return HttpService:JSONDecode(raw) end)
    if not ok or not data or not data.data then return nil end

    local valid = {}
    for _, s in ipairs(data.data) do
        if s.playing and s.maxPlayers and s.playing > 2 and s.playing < 10 and s.id ~= game.JobId then
            table.insert(valid, {id = s.id, players = s.playing})
        end
    end
    table.sort(valid, function(a, b) return a.players > b.players end) -- Prefer MORE players = more kills

    if #valid > 0 then
        local pool = math.min(5, #valid)
        local pick = valid[math.random(1, pool)]
        local ids = {}
        for _, v in ipairs(valid) do table.insert(ids, v.id) end
        SERVER_LIST_CACHE = ids
        LAST_FETCH_TIME = tick()
        return pick.id
    end
    return nil
end

