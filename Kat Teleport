-- INITIALIZATION
-- ═══════════════════════════════════════
LoadConfig()
local StatusLabel, StartBtn, KillLabel, HopLabel, TimerLabel = CreateGUI()

StartBtn.MouseButton1Click:Connect(function()
    if scriptState.Stopped then
        scriptState.SessionId = scriptState.SessionId + 1
        scriptState.Stopped = false
        StartBtn.Text = "STOP FARM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        Config.SessionKills = 0
        task.spawn(function() Main(StatusLabel, KillLabel, HopLabel, TimerLabel) end)
    else
        scriptState.Stopped = true
        StopFlyLock()
        DisableNoclip()
        StartBtn.Text = "START FARM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        StatusLabel.Text = "Stopped."
        TimerLabel.Text = "⏱️ Next Hop: --:--"
    end
end)

-- Auto-start after server hop
if isfile(CONFIG_FILE) then
    local s, d = pcall(function() return HttpService:JSONDecode(readfile(CONFIG_FILE)) end)
    if s and d and d.HopCount and d.HopCount > 0 then
        scriptState.Stopped = false
        StartBtn.Text = "STOP FARM"
        StartBtn.BackgroundColor3 = Color3.fromRGB(150, 0, 0)
        Config.SessionKills = 0
        task.spawn(function() Main(StatusLabel, KillLabel, HopLabel, TimerLabel) end)
    end
end
