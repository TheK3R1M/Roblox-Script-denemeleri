-- Orbit logic is now within StartFlyLock for dynamic rotation


local function StartFlyLock(targetPlayer)
    StopFlyLock() -- Clean previous lock
    flyLockTarget = targetPlayer
    
    local char = LocalPlayer.Character
    if not char then return end
    local hrp = char:FindFirstChild("HumanoidRootPart")
    if not hrp then return end
    
    -- Zero-gravity BodyVelocity
    flyBodyVelocity = Instance.new("BodyVelocity")
    flyBodyVelocity.Velocity = Vector3.new(0, 0, 0)
    flyBodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    flyBodyVelocity.P = 10000
    flyBodyVelocity.Parent = hrp
    
    local orbitAngle = 0
    -- RenderStepped: Fast 3D Orbiting Lock
    flyLockConnection = RunService.RenderStepped:Connect(function(dt)
        local tChar = flyLockTarget and flyLockTarget.Character
        local tHRP = tChar and tChar:FindFirstChild("HumanoidRootPart")
        local myHRP = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
        
        if tHRP and myHRP then
            orbitAngle = orbitAngle + (dt * ORBIT_SPEED)
            
            -- Detect if target has a knife
            local isKnife = false
            for _, item in ipairs(tChar:GetChildren()) do
                if item:IsA("Tool") and item.Name:lower():find("knife") then
                    isKnife = true
                    break
                end
            end

            -- 🌀 ORBIT GEOMETRY
            local x = math.cos(orbitAngle) * ATTACK_OFFSET
            local z = math.sin(orbitAngle) * ATTACK_OFFSET
            local y = math.sin(orbitAngle * 0.5) * (ATTACK_OFFSET * 0.5)
            
            local targetCFrame = tHRP.CFrame
            if isKnife then
                -- Target has a knife, stay behind them (Backstab Focus)
                -- We offset the entire orbit center to 4.5 studs behind the player
                targetCFrame = tHRP.CFrame * CFrame.new(0, 0, 4.5)
            end

            local finalPos = (targetCFrame * CFrame.new(x, y, z)).Position
            myHRP.CFrame = CFrame.new(finalPos, tHRP.Position)
        end
    end)
end

function StopFlyLock()
    flyLockTarget = nil
    if flyLockConnection then
        flyLockConnection:Disconnect()
        flyLockConnection = nil
    end
    if flyBodyVelocity then
        flyBodyVelocity:Destroy()
        flyBodyVelocity = nil
    end
end

