local function VerifyKill(targetName)
    local verified = false
    for attempt = 1, 30 do
        pcall(function()
            local killFeed = LocalPlayer.PlayerGui:FindFirstChild("GameUI")
                and LocalPlayer.PlayerGui.GameUI:FindFirstChild("HUD")
                and LocalPlayer.PlayerGui.GameUI.HUD:FindFirstChild("KillFeed")
            if killFeed then
                for _, child in ipairs(killFeed:GetChildren()) do
                    if child.Name == "KillFeedTemplate" and child:FindFirstChild("Contents") then
                        local k = child.Contents:FindFirstChild("Killer")
                        local t = child.Contents:FindFirstChild("Target")
                        if k and t and k.Text == LocalPlayer.Name and t.Text == targetName then
                            verified = true
                        end
                    end
                end
            end
        end)
        if verified then break end
        task.wait(0.1)
    end
    return verified
end

